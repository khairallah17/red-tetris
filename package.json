{
  "name": "red_tetris",
  "version": "1.0.0",
  "description": "Multiplayer Tetris - Full Stack JavaScript",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev:server": "nodemon src/server/index.js",
    "dev:client": "webpack serve --mode development",
    "build": "webpack --mode production",
    "test": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^6.11.2",
    "redux": "^4.2.1",
    "redux-thunk": "^2.4.2",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.21.8",
    "@babel/preset-env": "^7.21.5",
    "@babel/preset-react": "^7.18.6",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "babel-jest": "^29.5.0",
    "babel-loader": "^9.1.2",
    "css-loader": "^6.7.4",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "nodemon": "^2.0.22",
    "style-loader": "^3.3.2",
    "webpack": "^5.82.1",
    "webpack-cli": "^5.1.1",
    "webpack-dev-server": "^4.15.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEach": [
      "@testing-library/jest-dom"
    ],
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "moduleNameMapper": {
      "\\.(css|less|scss)$": "<rootDir>/test/__mocks__/styleMock.js"
    },
    "collectCoverageFrom": [
      "src/client/utils/board.js",
      "src/client/reducers/*.js",
      "src/client/actions/types.js",
      "src/server/models/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "functions": 70,
        "lines": 70,
        "branches": 50
      }
    }
  }
}
